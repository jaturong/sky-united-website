\b0 \cf2 "\uc0\u3594 \u3640 \u3604 \u3649 \u3621 \u3632 \u3648 \u3588 \u3619 \u3639 \u3656 \u3629 \u3591 \u3649 \u3605 \u3656 \u3591 \u3585 \u3634 \u3618 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3627 \u3657 \u3629 \u3591 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617  (Cleanroom Garments & Suits) \u3588 \u3639 \u3629 \u3648 \u3588 \u3619 \u3639 \u3656 \u3629 \u3591 \u3649 \u3605 \u3656 \u3591 \u3585 \u3634 \u3618 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3594 \u3609 \u3636 \u3604 \u3614 \u3636 \u3648 \u3624 \u3625 \u3607 \u3637 \u3656 \u3606 \u3641 \u3585 \u3629 \u3629 \u3585 \u3649 \u3610 \u3610 \u3617 \u3634 \u3648 \u3614 \u3639 \u3656 \u3629 \u3621 \u3604 \u3585 \u3634 \u3619 \u3611 \u3609 \u3648 \u3611 \u3639 \u3657 \u3629 \u3609 \u3586 \u3629 \u3591 \u3629 \u3609 \u3640 \u3616 \u3634 \u3588 \u3613 \u3640 \u3656 \u3609 \u3649 \u3621 \u3632 \u3585 \u3634 \u3619 \u3648 \u3585 \u3636 \u3604 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (ESD) \u3651 \u3609 \u3627 \u3657 \u3629 \u3591 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3649 \u3621 \u3632 \u3626 \u3616 \u3634 \u3614 \u3649 \u3623 \u3604 \u3621 \u3657 \u3629 \u3617 \u3585 \u3634 \u3619 \u3612 \u3621 \u3636 \u3605 \u3607 \u3637 \u3656 \u3652 \u3623 \u3605 \u3656 \u3629 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605 \u3612 \u3621 \u3636 \u3605 \u3616 \u3633 \u3603 \u3601 \u3660 \u3609 \u3637 \u3657 \u3652 \u3604 \u3657 \u3619 \u3633 \u3610 \u3585 \u3634 \u3619 \u3651 \u3594 \u3657 \u3591 \u3634 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3649 \u3614 \u3619 \u3656 \u3627 \u3621 \u3634 \u3618 \u3651 \u3609 \u3629 \u3640 \u3605 \u3626 \u3634 \u3627 \u3585 \u3619 \u3619 \u3617 \u3648 \u3595 \u3617 \u3636 \u3588 \u3629 \u3609 \u3604 \u3633 \u3585 \u3648 \u3605 \u3629 \u3619 \u3660 , \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 , \u3649 \u3612 \u3656 \u3609 \u3623 \u3591 \u3592 \u3619 \u3614 \u3636 \u3617 \u3614 \u3660  (PCB), \u3618 \u3634 \u3649 \u3621 \u3632 \u3648 \u3623 \u3594 \u3616 \u3633 \u3603 \u3601 \u3660 , \u3629 \u3640 \u3611 \u3585 \u3619 \u3603 \u3660 \u3629 \u3629 \u3611 \u3605 \u3636 \u3585  (\u3648 \u3621 \u3609 \u3626 \u3660 \u3649 \u3621 \u3632 \u3585 \u3619 \u3632 \u3592 \u3585 ) \u3619 \u3623 \u3617 \u3606 \u3638 \u3591 \u3629 \u3640 \u3605 \u3626 \u3634 \u3627 \u3585 \u3619 \u3619 \u3617 \u3585 \u3634 \u3619 \u3612 \u3621 \u3636 \u3605 \u3594 \u3636 \u3657 \u3609 \u3626 \u3656 \u3623 \u3609 \u3588 \u3623 \u3634 \u3617 \u3649 \u3617 \u3656 \u3609 \u3618 \u3635 \u3626 \u3641 \u3591  \u3594 \u3640 \u3604 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3592 \u3632 \u3594 \u3656 \u3623 \u3618 \u3619 \u3633 \u3585 \u3625 \u3634 \u3617 \u3634 \u3605 \u3619 \u3600 \u3634 \u3609 \u3588 \u3623 \u3634 \u3617 \u3626 \u3632 \u3629 \u3634 \u3604  \u3614 \u3619 \u3657 \u3629 \u3617 \u3607 \u3633 \u3657 \u3591 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3612 \u3621 \u3636 \u3605 \u3616 \u3633 \u3603 \u3601 \u3660 \u3607 \u3637 \u3656 \u3610 \u3629 \u3610 \u3610 \u3634 \u3591 \u3649 \u3621 \u3632 \u3585 \u3619 \u3632 \u3610 \u3623 \u3609 \u3585 \u3634 \u3619 \u3612 \u3621 \u3636 \u3605 \u3651 \u3627 \u3657 \u3611 \u3621 \u3629 \u3604 \u3616 \u3633 \u3618 \u3592 \u3634 \u3585 \u3613 \u3640 \u3656 \u3609 \u3621 \u3632 \u3629 \u3629 \u3591  \u3648 \u3626 \u3657 \u3609 \u3651 \u3618 \u3612 \u3657 \u3634 \u3649 \u3621 \u3632 \u3626 \u3636 \u3656 \u3591 \u3611 \u3609 \u3648 \u3611 \u3639 \u3657 \u3629 \u3609 \u3607 \u3637 \u3656 \u3617 \u3634 \u3592 \u3634 \u3585 \u3605 \u3633 \u3623 \u3610 \u3640 \u3588 \u3588 \u3621 \u3594 \u3640 \u3604 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3586 \u3629 \u3591 \u3648 \u3619 \u3634 \u3612 \u3621 \u3636 \u3605 \u3592 \u3634 \u3585 \u3623 \u3633 \u3626 \u3604 \u3640 \u3607 \u3637 \u3656 \u3648 \u3585 \u3636 \u3604 \u3586 \u3640 \u3618 \u3605 \u3656 \u3635  (Low-lint) \u3649 \u3621 \u3632 \u3611 \u3621 \u3629 \u3604 \u3616 \u3