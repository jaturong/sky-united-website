\

\b0 \uc0\u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (Static Shielding Bags: SSB) \u3627 \u3619 \u3639 \u3629 \u3607 \u3637 \u3656 \u3648 \u3619 \u3637 \u3618 \u3585 \u3623 \u3656 \u3634  \u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609  ESD \u3627 \u3619 \u3639 \u3629 \u3606 \u3640 \u3591 \u3585 \u3633 \u3609 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  \u3606 \u3641 \u3585 \u3629 \u3629 \u3585 \u3649 \u3610 \u3610 \u3617 \u3634 \u3648 \u3611 \u3655 \u3609 \u3614 \u3636 \u3648 \u3624 \u3625 \u3648 \u3614 \u3639 \u3656 \u3629 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3594 \u3636 \u3657 \u3609  \u3626 \u3656 \u3623 \u3609 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3607 \u3637 \u3656 \u3617 \u3637 \u3588 \u3623 \u3634 \u3617 \u3652 \u3623 \u3605 \u3656 \u3629 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  \u3592 \u3634 \u3585 \u3585 \u3634 \u3619 \u3588 \u3634 \u3618 \u3611 \u3619 \u3632 \u3592 \u3640 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (ESD) \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  \u3613 \u3640 \u3656 \u3609  \u3649 \u3621 \u3632 \u3588 \u3623 \u3634 \u3617 \u3648 \u3626 \u3637 \u3618 \u3627 \u3634 \u3618 \u3619 \u3632 \u3627 \u3623 \u3656 \u3634 \u3591 \u3585 \u3634 \u3619 \u3592 \u3633 \u3604 \u3648 \u3585 \u3655 \u3610 \u3649 \u3621 \u3632 \u3585 \u3634 \u3619 \u3586 \u3609 \u3626 \u3656 \u3591 \u3606 \u3640 \u3591  SSB \u3606 \u3641 \u3585 \u3651 \u3594 \u3657  \u3629 \u3618 \u3656 \u3634 \u3591 \u3649 \u3614 \u3619 \u3656 \u3627 \u3621 \u3634 \u3618 \u3651 \u3609 \u3591 \u3634 \u3609 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3648 \u3595 \u3617 \u3636 \u3588 \u3629 \u3609 \u3604 \u3633 \u3585 \u3648 \u3605 \u3629 \u3619 \u3660  \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660  PCB \u3630 \u3634 \u3619 \u3660 \u3604 \u3604 \u3636 \u3626 \u3585 \u3660  (HDD) IC \u3649 \u3621 \u3632 \u3585 \u3634 \u3619 \u3610 \u3619 \u3619 \u3592 \u3640 \u3594 \u3636 \u3657 \u3609 \u3626 \u3656 \u3623 \u3609 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3607 \u3637 \u3656 \u3652 \u3623 \u3605 \u3656 \u3629 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605 \u3629 \u3639 \u3656 \u3609  \u3654  \u3595 \u3638 \u3656 \u3591 \u3592 \u3635 \u3648 \u3611 \u3655 \u3609  \u3605 \u3657 \u3629 \u3591 \u3617 \u3637 \u3585 \u3634 \u3619 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609  ESD \u3607 \u3637 \u3656 \u3648 \u3594 \u3639 \u3656 \u3629 \u3606 \u3639 \u3629 \u3652 \u3604 \u3657 \u3612 \u3621 \u3636 \u3605 \u3592 \u3634 \u3585 \u3623 \u3633 \u3626 \u3604 \u3640 \u3609 \u3635 \u3652 \u3615 \u3615 \u3657 \u3634 \u3649 \u3621 \u3632 \u3623 \u3633 \u3626 \u3604 \u3640 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  \u3612 \u3621 \u3636 \u3605 \u3616 \u3633 \u3603 \u3601 \u3660  SSB \u3586 \u3629 \u3591 \u3648 \u3619 \u3634 \u3594 \u3656 \u3623 \u3618 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3629 \u3640 \u3611 \u3585 \u3619 \u3603 \u3660 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3652 \u3604 \u3657 \u3629 \u3618 \u3656 \u3634 \u3591 \u3617 \u3637  \u3611 \u3619 \u3632 \u3626 \u3636 \u3607 \u3608 \u3636 \u3616 \u3634 \u3614  \u3614 \u3619 \u3657 \u3629 \u3617 \u3619 \u3629 \u3591 \u3619 \u3633 \u3610 \u3617 \u3634 \u3605 \u3619 \u3600 \u3634 \u3609 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3649 \u3621 \u3632 \u3586 \u3657 \u3629 \u3585 \u3635 \u3627 \u3609 \u3604 \u3604 \u3657 \u3634 \u3609 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3629 \u3640 \u3605 \u3626 \u3634 \u3627 \u3585 \u3619 \u3619 \u3617  \u3651 \u3609 \u3600 \u3634 \u3609 \u3632 \u3612 \u3641 \u3657 \u3651 \u3627 \u3657 \u3610 \u3619 \u3636 \u3585 \u3634 \u3619 \u3650 \u3595 \u3621 \u3641 \u3594 \u3633 \u3609 \u3604 \u3657 \u3634 \u3609 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660  ESD \u3649 \u3621 \u3632 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3607 \u3637 \u3656 \u3648 \u3594 \u3639 \u3656 \u3629 \u3606 \u3639 \u3629 \u3652 \u3604 \u3657 \
