\uc0\u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609 \u3649 \u3621 \u3632 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (Moisture Barrier Bags - MBB) \u3612 \u3641 \u3657 \u3612 \u3621 \u3636 \u3605 \u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609 \u3649 \u3621 \u3632 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605 \u3651 \u3609 \u3611 \u3619 \u3632 \u3648 \u3607 \u3624 \u3652 \u3607 \u3618  | \u3595 \u3633 \u3614 \u3614 \u3621 \u3634 \u3618 \u3648 \u3629 \u3629 \u3619 \u3660 \u3612 \u3641 \u3657 \u3592 \u3633 \u3604 \
\uc0\u3592 \u3635 \u3627 \u3609 \u3656 \u3634 \u3618  MBB\

\b0 \uc0\u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609 \u3649 \u3621 \u3632 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (MBB) \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3629 \u3640 \u3611 \u3585 \u3619 \u3603 \u3660 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3649 \u3621 \u3632 \u3648 \u3595 \u3617 \u3636 \u3588 \u3629 \u3609 \u3604 \u3633 \u3585 \u3648 \u3605 \u3629 \u3619 \u3660 \u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609  (Moisture Barrier Bags\
\uc0\u3627 \u3619 \u3639 \u3629  MBB) \u3627 \u3619 \u3639 \u3629 \u3607 \u3637 \u3656 \u3619 \u3641 \u3657 \u3592 \u3633 \u3585 \u3585 \u3633 \u3609 \u3651 \u3609 \u3594 \u3639 \u3656 \u3629  \u3606 \u3640 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609  ESD \u3627 \u3619 \u3639 \u3629  \u3606 \u3640 \u3591 \u3615 \u3629 \u3618 \u3621 \u3660 \u3629 \u3621 \u3641 \u3617 \u3636 \u3648 \u3609 \u3637 \u3618 \u3617  \u3606 \u3641 \u3585 \u3629 \u3629 \u3585 \u3649 \u3610 \u3610 \u3617 \u3634 \u3648 \u3614 \u3639 \u3656 \u3629 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3594 \u3636 \u3657 \u3609 \u3626 \u3656 \u3623 \u3609 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3607 \u3637 \u3656 \u3610 \u3629 \u3610 \u3610 \u3634 \u3591 \u3649 \u3621 \u3632 \u3652 \u3623 \u3605 \u3656 \u3629 \u3626 \u3636 \u3656 \u3591 \u3585 \u3619 \u3632 \u3605 \u3640 \u3657 \u3609 \
\uc0\u3592 \u3634 \u3585 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609  \u3585 \u3634 \u3619 \u3588 \u3634 \u3618 \u3611 \u3619 \u3632 \u3592 \u3640 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  (ESD) \u3613 \u3640 \u3656 \u3609  \u3649 \u3621 \u3632 \u3585 \u3634 \u3619 \u3611 \u3609 \u3648 \u3611 \u3639 \u3657 \u3629 \u3609 \u3605 \u3656 \u3634 \u3591 \u3654 \u3612 \u3621 \u3636 \u3605 \u3616 \u3633 \u3603 \u3601 \u3660  MBB \u3586 \u3629 \u3591 \u3648 \u3619 \u3634 \u3606 \u3641 \u3585 \u3609 \u3635 \u3652 \u3611 \u3651 \u3594 \u3657 \u3591 \u3634 \u3609 \u3629 \u3618 \u3656 \u3634 \u3591 \u3649 \u3614 \u3619 \u3656 \u3627 \u3621 \u3634 \u3618 \u3651 \u3609 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3648 \u3595 \u3617 \u3636 \u3588 \u3629 \u3609 \u3604 \u3633 \u3585 \
\uc0\u3648 \u3605 \u3629 \u3619 \u3660 , \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3649 \u3612 \u3656 \u3609 \u3623 \u3591 \u3592 \u3619 \u3614 \u3636 \u3617 \u3614 \u3660  (PCB) \u3619 \u3623 \u3617 \u3606 \u3638 \u3591 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3594 \u3636 \u3657 \u3609 \u3626 \u3656 \u3623 \u3609 \u3607 \u3637 \u3656 \u3652 \u3623 \u3605 \u3656 \u3629 \u3652 \u3615 \u3615 \u3657 \u3634 \u3626 \u3606 \u3636 \u3605  \u3648 \u3614 \u3639 \u3656 \u3629 \u3617 \u3629 \u3610 \u3585 \u3634 \u3619 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3607 \u3637 \u3656 \u3648 \u3594 \u3639 \u3656 \u3629 \u3606 \u3639 \u3629 \u3652 \u3604 \u3657 \u3626 \u3635 \u3627 \u3619 \u3633 \u3610 \u3629 \u3640 \u3605 \u3626 \u3634 \u3627 \u3585 \u3619 \u3619 \u3617 \u3652 \u3630 \u3648 \u3607 \u3588 \u3651 \u3609 \u3600 \u3634 \u3609 \u3632 \u3612 \u3641 \u3657 \
\uc0\u3651 \u3627 \u3657 \u3610 \u3619 \u3636 \u3585 \u3634 \u3619 \u3650 \u3595 \u3621 \u3641 \u3594 \u3633 \u3609 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660  ESD \u3649 \u3621 \u3632 \u3610 \u3619 \u3619 \u3592 \u3640 \u3616 \u3633 \u3603 \u3601 \u3660 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \u3607 \u3637 \u3656 \u3652 \u3604 \u3657 \u3619 \u3633 \u3610 \u3588 \u3623 \u3634 \u3617 \u3652 \u3623 \u3657 \u3623 \u3634 \u3591 \u3651 \u3592  \u3610 \u3619 \u3636 \u3625 \u3633 \u3607  \u3626 \u3585 \u3634 \u3618  \u3618 \u3641 \u3652 \u3609 \u3648 \u3605 \u3655 \u3604  \u3629 \u3636 \u3609 \u3604 \u3633 \u3626 \u3648 \u3607 \u3619 \u3637 \u3618 \u3621  (\u3611 \u3619 \u3632 \u3648 \u3607 \u3624 \u3652 \u3607 \u3618 ) \u3592 \u3635 \u3585 \u3633 \u3604  \u3612 \u3621 \u3636 \u3605 \u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609 \
\uc0\u3588 \u3640 \u3603 \u3616 \u3634 \u3614 \u3626 \u3641 \u3591 \u3651 \u3609 \u3611 \u3619 \u3632 \u3648 \u3607 \u3624 \u3652 \u3607 \u3618  \u3604 \u3657 \u3623 \u3618 \u3588 \u3640 \u3603 \u3616 \u3634 \u3614 \u3607 \u3637 \u3656 \u3648 \u3626 \u3606 \u3637 \u3618 \u3619  \u3619 \u3632 \u3618 \u3632 \u3648 \u3623 \u3621 \u3634 \u3651 \u3609 \u3585 \u3634 \u3619 \u3612 \u3621 \u3636 \u3605 \u3607 \u3637 \u3656 \u3619 \u3623 \u3604 \u3648 \u3619 \u3655 \u3623  (Lead time) \u3649 \u3621 \u3632 \u3648 \u3611 \u3655 \u3609 \u3652 \u3611 \u3605 \u3634 \u3617 \u3617 \u3634 \u3605 \u3619 \u3600 \u3634 \u3609 \u3585 \u3634 \u3619 \u3612 \u3621 \u3636 \u3605 \u3651 \u3609 \u3627 \u3657 \u3629 \u3591 \u3588 \u3621 \u3637 \u3609 \u3619 \u3641 \u3617 \

\b \uc0\u3588 \u3640 \u3603 \u3626 \u3617 \u3610 \u3633 \u3605 \u3636 \u3648 \u3604 \u3656 \u3609 \u3586 \u3629 \u3591 \u3612 \u3621 \u3636 \u3605 \u3616 \u3633 \u3603 \u3601 \u3660 \u3606 \u3640 \u3591 \u3611 \u3657 \u3629 \u3591 \u3585 \u3633 \u3609 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609  (MBB) \u3611 \u3619 \u3632 \u3626 \u3636 \u3607 \u3608 \u3636 \u3616 \u3634 \u3614 \u3626 \u3641 \u3591  \u3652 \u3604 \u3657 \u3619 \u3633 \u3610 \u3585 \u3634 \u3619 \u3629 \u3629 \u3585 \u3649 \u3610 \u3610 \u3617 \u3634 \u3648 \u3614 \u3639 \u3656 \u3629 \u3611 \u3585 \u3611 \u3657 \u3629 \u3591 \u3594 \u3636 \u3657 \u3609 \u3626 \u3656 \u3623 \u3609 \u3629 \u3636 \u3648 \u3621 \u3655 \u3585 \u3607 \u3619 \u3629 \u3609 \u3636 \u3585 \u3626 \u3660 \u3607 \u3637 \u3656 \u3610 \u3629 \u3610 \u3610 \u3634 \u3591 \u3592 \u3634 \u3585 \u3588 \u3623 \u3634 \u3617 \u3594 \u3639 \u3657 \u3609 ,\
